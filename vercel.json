{
  "rewrites": [
    { "source": "/", "destination": "/api/site" },
    { "source": "/index.html", "destination": "/api/site" },
    { "source": "/site.html", "destination": "/api/site" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
